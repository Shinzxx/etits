--  TOGGLE CARD FUNCTION (with description and loading bar)
-- ============================================================================
local function createToggleCard(name, description, icon, order, color)
	color = color or Color3.fromRGB(0, 150, 255)
	local cardHeight = isMobile and 100 or 110

	local card = Instance.new("Frame")
	card.Name = name .. "Card"
	card.Size = UDim2.new(1, 0, 0, cardHeight)
	card.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
	card.BackgroundTransparency = 0.2
	card.BorderSizePixel = 0
	card.LayoutOrder = order
	card.Parent = contentFrame
	card.ClipsDescendants = true

	local cardCorner = Instance.new("UICorner")
	cardCorner.CornerRadius = UDim.new(0, 12)
	cardCorner.Parent = card

	local cardStroke = Instance.new("UIStroke")
	cardStroke.Color = color
	cardStroke.Transparency = 0.6
	cardStroke.Thickness = 1
	cardStroke.Parent = card

	local cardGrad = Instance.new("UIGradient")
	cardGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(8, 8, 8)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
	})
	cardGrad.Rotation = 135
	cardGrad.Parent = card

	-- Icon (optional)
	local iconLabel = Instance.new("TextLabel")
	iconLabel.Size = UDim2.new(0, 36, 0, 36)
	iconLabel.Position = UDim2.new(0, 12, 0, 12)
	iconLabel.BackgroundColor3 = color
	iconLabel.Text = icon
	iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	iconLabel.TextScaled = true
	iconLabel.Font = Enum.Font.GothamBold
	iconLabel.BorderSizePixel = 0
	iconLabel.ZIndex = 2
	iconLabel.Parent = card

	local iconCorner = Instance.new("UICorner")
	iconCorner.CornerRadius = UDim.new(0, 8)
	iconCorner.Parent = iconLabel

	-- Title
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, -60, 0, 22)
	titleLabel.Position = UDim2.new(0, 54, 0, 12)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = name
	titleLabel.TextColor3 = Color3.fromRGB(220, 230, 255)
	titleLabel.TextScaled = false
	titleLabel.TextSize = isMobile and 14 or 16
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.ZIndex = 2
	titleLabel.Parent = card

	-- Description
	local descLabel = Instance.new("TextLabel")
	descLabel.Size = UDim2.new(1, -60, 0, 18)
	descLabel.Position = UDim2.new(0, 54, 0, 34)
	descLabel.BackgroundTransparency = 1
	descLabel.Text = description
	descLabel.TextColor3 = Color3.fromRGB(150, 170, 200)
	descLabel.TextScaled = false
	descLabel.TextSize = isMobile and 10 or 12
	descLabel.Font = Enum.Font.Gotham
	descLabel.TextXAlignment = Enum.TextXAlignment.Left
	descLabel.ZIndex = 2
	descLabel.Parent = card

	-- Status Label (Inactive/Active)
	local statusLabel = Instance.new("TextLabel")
	statusLabel.Name = "StatusLabel"
	statusLabel.Size = UDim2.new(0, 80, 0, 18)
	statusLabel.Position = UDim2.new(0, 54, 0, 54)
	statusLabel.BackgroundTransparency = 1
	statusLabel.Text = "Inactive"
	statusLabel.TextColor3 = Color3.fromRGB(120, 140, 180)
	statusLabel.TextScaled = false
	statusLabel.TextSize = isMobile and 10 or 12
	statusLabel.Font = Enum.Font.GothamBold
	statusLabel.TextXAlignment = Enum.TextXAlignment.Left
	statusLabel.ZIndex = 2
	statusLabel.Parent = card

	-- Toggle Switch
	local toggleTrack = Instance.new("Frame")
	toggleTrack.Size = UDim2.new(0, 50, 0, 26)
	toggleTrack.Position = UDim2.new(1, -64, 0, 40)
	toggleTrack.BackgroundColor3 = Color3.fromRGB(40, 45, 60)
	toggleTrack.BorderSizePixel = 0
	toggleTrack.ZIndex = 2
	toggleTrack.Parent = card

	local trackCorner = Instance.new("UICorner")
	trackCorner.CornerRadius = UDim.new(1, 0)
	trackCorner.Parent = toggleTrack

	local trackStroke = Instance.new("UIStroke")
	trackStroke.Color = color
	trackStroke.Transparency = 0.5
	trackStroke.Thickness = 1
	trackStroke.Parent = toggleTrack

	local toggleKnob = Instance.new("Frame")
	toggleKnob.Size = UDim2.new(0, 20, 0, 20)
	toggleKnob.Position = UDim2.new(0, 3, 0.5, -10)
	toggleKnob.BackgroundColor3 = color
	toggleKnob.BorderSizePixel = 0
	toggleKnob.ZIndex = 3
	toggleKnob.Parent = toggleTrack

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = toggleKnob

	-- Loading Bar (at bottom)
	local loadingBar = Instance.new("Frame")
	loadingBar.Name = "LoadingBar"
	loadingBar.Size = UDim2.new(0, 0, 0, 4)
	loadingBar.Position = UDim2.new(0, 0, 1, -4)
	loadingBar.AnchorPoint = Vector2.new(0, 1)
	loadingBar.BackgroundColor3 = color
	loadingBar.BackgroundTransparency = 0.3
	loadingBar.BorderSizePixel = 0
	loadingBar.ZIndex = 5
	loadingBar.Visible = false
	loadingBar.Parent = card

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(0, 2)
	barCorner.Parent = loadingBar

	local clickBtn = Instance.new("TextButton")
	clickBtn.Size = UDim2.new(1, 0, 1, 0)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text = ""
	clickBtn.ZIndex = 4
	clickBtn.Parent = card

	-- State
	local isOn = false
	local isLoading = false
	local currentTween = nil

	local function stopLoading()
		if currentTween then
			currentTween:Cancel()
			currentTween = nil
		end
		loadingBar.Visible = false
		loadingBar.Size = UDim2.new(0, 0, 0, 4)
	end

	local function setVisualState(state, loading)
		local knobPos = state and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
		local trackColor = state and color or Color3.fromRGB(40, 45, 60)
		local knobColor = state and color or color:lerp(Color3.new(1,1,1), 0.3)
		local strokeColor = state and color or color
		local cardStrokeColor = state and color or color
		local cardStrokeTransp = state and 0.2 or 0.6
		local iconBg = state and color or color:lerp(Color3.new(0,0,0), 0.5)

		TweenService:Create(toggleKnob, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = knobPos, BackgroundColor3 = knobColor}):Play()
		TweenService:Create(toggleTrack, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = trackColor}):Play()
		TweenService:Create(trackStroke, TweenInfo.new(0.2), {Color = strokeColor}):Play()
		TweenService:Create(cardStroke, TweenInfo.new(0.2), {Color = cardStrokeColor, Transparency = cardStrokeTransp}):Play()
		TweenService:Create(iconLabel, TweenInfo.new(0.2), {BackgroundColor3 = iconBg}):Play()

		if loading then
			statusLabel.Text = "Activating..."
			statusLabel.TextColor3 = color
		else
			statusLabel.Text = state and "Active" or "Inactive"
			statusLabel.TextColor3 = state and color or Color3.fromRGB(120, 140, 180)
		end

		-- Press effect
		local punchTween = TweenService:Create(card, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
		punchTween:Play()
		punchTween.Completed:Connect(function()
			TweenService:Create(card, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.2}):Play()
		end)
	end

	local function turnOn()
		if isOn then return end
		isOn = true
		isLoading = true
		setVisualState(true, true)

		loadingBar.Visible = true
		loadingBar.Size = UDim2.new(0, 0, 0, 4)
		currentTween = TweenService:Create(loadingBar, TweenInfo.new(5, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 0, 4)})
		currentTween:Play()
		currentTween.Completed:Connect(function()
			if isLoading then
				isLoading = false
				setVisualState(true, false)
				stopLoading()
			end
		end)
	end

	local function turnOff()
		if not isOn then return end
		if isLoading then
			stopLoading()
		end
		isOn = false
		isLoading = false
		setVisualState(false, false)
		stopLoading()
	end

	clickBtn.MouseButton1Click:Connect(function()
		if isOn then turnOff() else turnOn() end
	end)

	-- Hover
	clickBtn.MouseEnter:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.15), {BackgroundTransparency = 0}):Play()
	end)
	clickBtn.MouseLeave:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.15), {BackgroundTransparency = 0.2}):Play()
	end)

	return card
end

